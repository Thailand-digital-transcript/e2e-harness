FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY target/*-keystore-init.jar app.jar
# BC FIPS jars ship unmodified (see the pom's maven-shade-plugin comment: shading them
# breaks BC FIPS's self-integrity check).
COPY target/lib/ lib/
# Explicit -cp with a `lib/*` wildcard rather than `java -jar`: `java -jar` ignores -cp
# and honours only the jar's Class-Path manifest entry, which would have to name each
# FIPS jar by exact filename — a hardcoded version that silently rots on a dependency
# bump. The wildcard is expanded by the JVM itself (not a shell, so exec form is fine)
# and picks up whatever maven-dependency-plugin copied into lib/.
ENTRYPOINT ["java", "-cp", "/app/app.jar:/app/lib/*", "com.wpanther.transcript.e2e.KeystoreGenerator"]
