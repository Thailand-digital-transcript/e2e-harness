FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY target/*-keystore-init.jar app.jar
# BC FIPS jars ship unmodified (see pom.xml maven-shade-plugin comment: shading them
# breaks BC FIPS's self-integrity check) and are resolved via app.jar's Class-Path
# manifest entry, relative to this directory.
COPY target/lib/ lib/
ENTRYPOINT ["java", "-jar", "app.jar"]
